# Copy to user_data/agent_llm.env and keep it out of git.

# OpenAI-compatible LLM endpoint.
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60

# Optional Tavily web tools.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=5

# Optional agent runtime.
AGENT_MAX_STEPS=12
AGENT_MONITOR_INTERVAL_SECONDS=60
# AGENT_PERMISSION_OVERRIDES=web_search:ask,web_fetch:ask
