# Copy this file to user_data/agent_llm.env and edit it locally.
# The real user_data/agent_llm.env file is ignored by git through user_data/*.
#
# Priority:
# 1. Runtime environment variables
# 2. user_data/agent_llm.env
# 3. Built-in defaults
#
# Do not include /chat/completions in the base URL. The agent appends it.

LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=zhipuai-coding-plan/glm-5.1
LLM_TIMEOUT_SECONDS=20
AGENT_MAX_STEPS=12
AGENT_MONITOR_INTERVAL_SECONDS=60

# Optional OpenCode-style permission overrides:
# AGENT_PERMISSION_OVERRIDES=web_search:allow,web_fetch:allow

# Tavily web_search / web_fetch:
TAVILY_API_KEY=replace-with-your-tavily-api-key
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=5

# OpenAI-compatible aliases are also supported:
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# OPENAI_API_KEY=replace-with-your-api-key
# OPENAI_MODEL=glm-5.1
